{"id":"CX_FULL_001","domain":"complex_numbers","type":"formal_reasoning_with_proof","instruction":"Prove that for any complex number z, z * conj(z) equals the sum of squares of its real and imaginary parts.","input":{"statement":"∀ z : ℂ, z * conj z = (z.re^2 + z.im^2 : ℝ)"},"reasoning_steps":[{"step":1,"content":"Split equality into real and imaginary parts using Complex.ext."},{"step":2,"content":"Compute real part using multiplication formula."},{"step":3,"content":"Substitute conjugate components."},{"step":4,"content":"Simplify algebraically."},{"step":5,"content":"Show imaginary part is zero."}],"lean_proof":{"code":["theorem mul_conj_z (z : ℂ) :","z * conj z = (z.re^2 + z.im^2 : ℝ) :=","by","apply Complex.ext","-- detailed calc proof here"],"style":"calc_atomic"},"final_answer":"z * conj(z) = z.re^2 + z.im^2.","common_errors":[{"error":"Wrong sign in multiplication","fix":"Use a*b - c*d formula"},{"error":"Confusing conjugate","fix":"Only imaginary part changes sign"}],"metadata":{"difficulty":"medium","verified":true}}

